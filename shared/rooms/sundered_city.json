  "events": [
    {
      "id": "king-rally-1",
      "on": { "kind": "bossHpBelowPct", "mob": "sundered_king", "pct": 0.66 },
      "actions": [
        { "kind": "announce", "text": "The Sundered King slams his blade against the marble — 'OATHBOUND! Your king commands you — RISE!'" },
        { "kind": "spawnMobs", "mob": "oathbound_sentinel", "count": 2, "radius": 7 }
      ]
    },
    {
      "id": "king-rally-2",
      "on": { "kind": "bossHpBelowPct", "mob": "sundered_king", "pct": 0.33 },
      "actions": [
        { "kind": "announce", "text": "The throne cracks. The rose window blazes. 'I did not kneel to the grave — I will NOT kneel to YOU!'" },
        { "kind": "spawnMobs", "mob": "oathbound_sentinel", "count": 3, "radius": 7 }
      ]
    },
    {
      "id": "king-falls",
      "on": { "kind": "bossDeath", "mob": "sundered_king" },
      "actions": [
        { "kind": "announce", "text": "The crown slips from Vaelric's helm and rings against the dais. Valdrenn exhales its long-held grief — the city is COLLAPSING. RUN! One minute!" },
        { "kind": "setRoomTimer", "sec": 60 }
      ]
    }
  ],
  "npcs": [
    {
      "id": "chronicler",
      "name": "Maera the Chronicler",
      "sprite": "npc_arcanist",
      "x": 134,
      "z": 220,
      "yaw": 0,
      "wanderRadius": 0,
      "dialog": [
        "Valdrenn was the jewel of the north — until its king bargained with something older than crowns.",
        "The war lasted nine days. On the tenth, the gates never opened again. He sits that throne still... what is left of him.",
        "Marauders pick the bones. The garrison never stopped marching. And the castle burns its lanterns for a court of ghosts.",
        "End the King and the city's grief collapses with him. When he falls, you will have ONE MINUTE to get out. Do not linger."
      ]
    }
  ]
