  "npcs": [
    {
      "id": "chronicler",
      "name": "Maera the Chronicler",
      "sprite": "npc_arcanist",
      "x": 134,
      "z": 220,
      "yaw": 0,
      "wanderRadius": 0,
      "dialog": [
        "Valdrenn was the jewel of the north — the only crown that ever said NO to the tribute. The war that answered lasted nine days.",
        "On the tenth day the gates never opened again. The First Tyrant left the king ON his throne — left him AS a lesson. He sits it still.",
        "Write it down, hunter: obedience killed the sands, defiance killed the north. The Charter had better be a third thing.",
        "When the Gatekeeper falls, the way to the court stands open — until the castle remembers itself. You'll have ONE MINUTE. Do not linger."
      ]
    }
  ]
